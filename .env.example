# --- Configuration WhatsApp (CallMeBot) ---
# Obtenir la clé API : https://www.callmebot.com/blog/free-api-whatsapp-messages/
WHATSAPP_PHONE="+22912345678"
WHATSAPP_API_KEY="votre_cle_api"

# --- Configuration Telegram ---
# Créer un bot via @BotFather sur Telegram
TELEGRAM_BOT_TOKEN="votre_token_bot"
TELEGRAM_CHAT_ID="votre_id_de_chat"

# --- Configuration Gmail ---
# Créer un mot de passe d'application dans les paramètres de sécurité Google
GMAIL_SENDER="votre.email@gmail.com"
GMAIL_APP_PASSWORD="votre_mot_de_passe_application_google"
GMAIL_RECEIVER="votre.email@gmail.com"
